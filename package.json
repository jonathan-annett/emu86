{
  "name": "emu86",
  "version": "0.0.1",
  "description": "A browser-oriented TypeScript x86 emulator framework. Roadmap: 8086 → 80286 real mode.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sst": "vitest run tests/sst",
    "start:elks": "tsc -p tsconfig.cli.json && node dist-cli/tools/elks/run.js",
    "build:elks-serial-image": "tsc -p tsconfig.cli.json && node dist-cli/tools/elks-build/build-serial-image.js",
    "build:elks-serial-image-minix": "tsc -p tsconfig.cli.json && node dist-cli/tools/elks-build/build-serial-image.js --filesystem minix",
    "build:elks-hd-image": "tsc -p tsconfig.cli.json && node dist-cli/tools/elks-build/fetch-hd-image.js",
    "build:elks-hd-mbr-images": "tsc -p tsconfig.cli.json && node dist-cli/tools/elks-build/fetch-hd-image.js --all",
    "start:elks-serial": "tsc -p tsconfig.cli.json && node dist-cli/tools/elks/run-serial.js",
    "dev:browser": "vite",
    "build:browser": "vite build",
    "preview:browser": "vite preview",
    "deploy:dev": "npm run build:browser && npx wrangler deploy",
    "deploy:prod": "npm run build:browser && npx wrangler deploy --env production"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
